node_modules/
dist/

# Fetched by scripts/fetch-assets.mjs on install, not worth committing.
public/wasm/
public/models/face_landmarker.task

# Third-party photoscan, licensed for use rather than redistribution. The app
# falls back to the procedural hand rig when it isn't present, so a fresh clone
# still runs - drop the file in locally to get the scanned hands back.
public/models/hands/

# Deploy bookkeeping written by the Firebase CLI, not source.
.firebase/
firebase-debug.log

# Built by `npm run build:apk`, 22MB, rebuilt from source - deployed via dist,
# never committed. The Gradle project and its build outputs are generated too.
public/gigil.apk
android/.gradle/
android/build/
android/app/build/
android/capacitor-cordova-android-plugins/
android/.idea/
android/local.properties

# Play upload signing key and its passwords. NEVER commit these. Losing the
# keystore means resetting the upload key with Google before you can publish an
# update, so back it up somewhere safe outside the repo.
android/gigil-upload.keystore
android/keystore.properties

*.local
.DS_Store
.vscode/

# Rebuildable Play upload artifact.
android/gigil-release.aab
android/app/build/outputs/
